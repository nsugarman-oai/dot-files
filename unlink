#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$ROOT_DIR/scripts/lib.sh"

usage() {
  cat <<EOF
Usage: ./unlink <name>

Names:
  all
EOF

  print_managed_target_names | sed 's/^/  /'
}

name="${1:-}"
target_spec=""

case "$name" in
  all) exec "$ROOT_DIR/scripts/unlink-all.sh" ;;
  help|-h|--help|"")
    usage
    ;;
  *)
    if ! target_spec="$(resolve_managed_target "$name")"; then
      printf 'Unknown unlink target: %s\n\n' "$name" >&2
      usage >&2
      exit 1
    fi

    IFS='|' read -r source_rel target_rel <<<"$target_spec"
    unlink_file "$source_rel" "$target_rel"
    ;;
esac
