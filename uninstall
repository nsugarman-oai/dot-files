#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage: ./uninstall <name>

Names:
  all
  zshrc
  zshrc-public
  config-git-aliases
  config-starship
  gitconfig
  local-bin-git-alias
EOF
}

name="${1:-}"

case "$name" in
  all) exec "$ROOT_DIR/scripts/uninstall-all.sh" ;;
  zshrc) exec "$ROOT_DIR/scripts/uninstall-zshrc.sh" ;;
  zshrc-public) exec "$ROOT_DIR/scripts/uninstall-zshrc-public.sh" ;;
  config-git-aliases) exec "$ROOT_DIR/scripts/uninstall-config-git-aliases.sh" ;;
  config-starship) exec "$ROOT_DIR/scripts/uninstall-config-starship.sh" ;;
  gitconfig) exec "$ROOT_DIR/scripts/uninstall-gitconfig.sh" ;;
  local-bin-git-alias) exec "$ROOT_DIR/scripts/uninstall-local-bin-git-alias.sh" ;;
  help|-h|--help|"")
    usage
    ;;
  *)
    printf 'Unknown uninstall target: %s\n\n' "$name" >&2
    usage >&2
    exit 1
    ;;
esac

