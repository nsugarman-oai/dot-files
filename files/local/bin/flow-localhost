#!/usr/bin/env bash
set -euo pipefail

DEFAULT_FLOWKIT_BACKEND_PORT=8081
DEFAULT_FLOWKIT_UI_PORT=5173
DEFAULT_TILT_PORT=10350
QUIET_AFTER_OUTPUT_SECONDS=2
ERROR_URL_DEBOUNCE_SECONDS=1
CRASH_CONTEXT_LINES=80

repo_root="$(pwd -P)"
tilt_work_dir="$repo_root/api/outerloop"
primary_repo_root="$HOME/code/openai"
worktree_setup_script="$repo_root/.codex/environments/monorepo_worktree_setup.sh"
script_name="${0##*/}"
verbose=0
shutdown_requested=0
server_pid=""
tracker_pid=""
watcher_pid=""
announcer_pid=""
title_updater_pid=""
runtime_dir=""

if [ -d "$primary_repo_root" ]; then
  primary_repo_root="$(cd "$primary_repo_root" && pwd -P)"
fi

blue_bold_text() {
  local text="$1"

  if [ -t 1 ] || [ -t 2 ] || [ -t 3 ] || [ -t 4 ]; then
    printf '\033[1;34m%s\033[0m' "$text"
    return
  fi

  printf '%s' "$text"
}

frontend_url() {
  local port="$1"

  blue_bold_text "http://localhost:$port/"
}

print_frontend_url_on_error() {
  local port="$1"

  printf '%s\n' "$(frontend_url "$port")" >&4
}

note_error_output() {
  local error_sequence_file="$1"
  local error_output_at_file="$2"
  local error_sequence=0

  error_sequence="$(cat "$error_sequence_file" 2>/dev/null || printf '0\n')"
  error_sequence=$((error_sequence + 1))

  printf '%s\n' "$error_sequence" >"$error_sequence_file"
  printf '%s\n' "$(date +%s)" >"$error_output_at_file"
}

announce_frontend_url_after_errors() {
  local frontend_port="$1"
  local error_sequence_file="$2"
  local error_output_at_file="$3"
  local stop_file="$4"
  local hold_file="$5"
  local printed_sequence=0
  local error_sequence=0
  local last_error_at=0
  local now=0

  while true; do
    error_sequence="$(cat "$error_sequence_file" 2>/dev/null || printf '0\n')"

    if [ -f "$stop_file" ] && [ "$error_sequence" -le "$printed_sequence" ]; then
      return 0
    fi

    if [ -f "$hold_file" ]; then
      sleep 1
      continue
    fi

    if [ "$error_sequence" -gt "$printed_sequence" ]; then
      last_error_at="$(cat "$error_output_at_file" 2>/dev/null || printf '0\n')"
      now="$(date +%s)"

      if [ $((now - last_error_at)) -ge "$ERROR_URL_DEBOUNCE_SECONDS" ]; then
        print_frontend_url_on_error "$frontend_port"
        printed_sequence="$error_sequence"
        continue
      fi
    fi

    sleep 1
  done
}

usage() {
  printf 'Usage: %s [-v|--verbose]\n' "$script_name"
}

branch_name_for_title() {
  local repo_dir="$1"
  local branch_name=""

  branch_name="$(git -C "$repo_dir" branch --show-current 2>/dev/null || true)"
  if [ -z "$branch_name" ]; then
    branch_name="$(git -C "$repo_dir" rev-parse --short HEAD 2>/dev/null || printf 'unknown\n')"
  fi

  case "$branch_name" in
    dev/codex/*)
      printf '%s\n' "${branch_name#dev/codex/}"
      ;;
    codex/*)
      printf '%s\n' "${branch_name#codex/}"
      ;;
    *)
      printf '%s\n' "$branch_name"
      ;;
  esac
}

terminal_title_text() {
  local frontend_port="$1"
  local repo_dir="$2"

  printf '%s | %s' "$frontend_port" "$(branch_name_for_title "$repo_dir")"
}

set_terminal_title() {
  local frontend_port="$1"
  local repo_dir="$2"

  [ -t 3 ] || return 0
  printf '\033]0;%s\007' "$(terminal_title_text "$frontend_port" "$repo_dir")" >&3
}

update_terminal_title_loop() {
  local frontend_port="$1"
  local repo_dir="$2"
  local last_title=""
  local title=""

  while true; do
    title="$(terminal_title_text "$frontend_port" "$repo_dir")"

    if [ "$title" != "$last_title" ]; then
      printf '\033]0;%s\007' "$title" >&3
      last_title="$title"
    fi

    sleep 60
  done
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -v|--verbose)
      verbose=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'flow-localhost: unknown option: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

port_is_taken() {
  local port="$1"
  lsof -tiTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

frontend_is_ready() {
  local port="$1"

  if command -v curl >/dev/null 2>&1; then
    curl --silent --fail --max-time 1 "http://127.0.0.1:$port/" >/dev/null 2>&1
    return
  fi

  port_is_taken "$port"
}

path_is_within() {
  local candidate="${1%/}"
  local root="${2%/}"

  [ "$candidate" = "$root" ] || [[ "$candidate/" == "$root/"* ]]
}

pid_cwd() {
  local pid="$1"

  lsof -a -d cwd -p "$pid" -Fn 2>/dev/null | awk '
    /^n/ {
      print substr($0, 2)
      exit
    }
  '
}

flowkit_pgids_for_target_dir() {
  local pid pgid cwd

  while IFS='|' read -r pid pgid; do
    [ -n "$pid" ] || continue

    cwd="$(pid_cwd "$pid")"
    if [ -z "$cwd" ] || ! path_is_within "$cwd" "$tilt_work_dir"; then
      continue
    fi

    printf '%s\n' "$pgid"
  done < <(
    ps -axo pid=,pgid=,command= | awk '
      /\/tilt up flowkit( --port [0-9]+)?$/ ||
      /uvicorn flowkit\.asgi:application/ ||
      /api\/outerloop\/flowkit_ui\/.*vite\/bin\/vite\.js --port/ {
        print $1 "|" $2
      }
    '
  )
}

kill_existing_flowkit_for_target_dir() {
  local pgids=""
  local pgid

  pgids="$(flowkit_pgids_for_target_dir)"
  pgids="$(printf '%s\n' "$pgids" | tr -d ' ' | sed '/^$/d' | sort -u)"
  [ -n "$pgids" ] || return 0

  while IFS= read -r pgid; do
    kill -TERM -- "-$pgid" 2>/dev/null || true
  done < <(printf '%s\n' "$pgids")

  sleep 1

  while IFS= read -r pgid; do
    kill -0 -- "-$pgid" 2>/dev/null || continue
    kill -KILL -- "-$pgid" 2>/dev/null || true
  done < <(printf '%s\n' "$pgids")
}

find_free_port_offset() {
  local offset=0
  local tilt_port=""
  local backend_port=""
  local ui_port=""

  while true; do
    tilt_port=$((DEFAULT_TILT_PORT + offset))
    backend_port=$((DEFAULT_FLOWKIT_BACKEND_PORT + offset))
    ui_port=$((DEFAULT_FLOWKIT_UI_PORT + offset))

    if ! port_is_taken "$tilt_port" &&
      ! port_is_taken "$backend_port" &&
      ! port_is_taken "$ui_port"; then
      printf '%s\n' "$offset"
      return 0
    fi

    offset=$((offset + 1))
  done
}

announce_when_frontend_is_ready() {
  local port="$1"
  local server_pid="$2"
  local started_at="$3"
  local last_output_file="$4"
  local last_output_at=""
  local announced_start=0
  local now=""

  while true; do
    if ! kill -0 "$server_pid" 2>/dev/null; then
      rm -f "$last_output_file"
      return 1
    fi

    now="$(date +%s)"
    last_output_at="$(cat "$last_output_file" 2>/dev/null || printf '%s\n' "$started_at")"

    if [ "$announced_start" -eq 0 ] && [ $((now - last_output_at)) -ge "$QUIET_AFTER_OUTPUT_SECONDS" ]; then
      printf 'starting localhost on %s\n' "$(blue_bold_text "http://localhost:$port/")" >&3
      announced_start=1
    fi

    if [ "$announced_start" -eq 1 ] && frontend_is_ready "$port"; then
      printf 'ready after %ss\n' "$((now - started_at))" >&3
      rm -f "$last_output_file"
      return 0
    fi

    sleep 1
  done
}

tilt_line_looks_like_error() {
  local line="$1"

  if printf '%s\n' "$line" | grep -Fqi 'localdog'; then
    return 1
  fi

  printf '%s\n' "$line" | grep -Eiq '(^|[[:space:]])(ERR!|ERROR|FATAL|PANIC)(:|[[:space:]]|$)|(^|[[:space:]])error:|^Traceback|(^|[[:space:]])Exception(:|[[:space:]]|$)|^[A-Za-z_][A-Za-z0-9_]*(Error|Exception|Exit):|(^|[[:space:]])failed([[:space:]]|$)|timed out|unable to'
}

track_tilt_output() {
  local last_output_file="$1"
  local recent_output_file="$2"
  local verbose_mode="$3"
  local error_sequence_file="$4"
  local error_output_at_file="$5"
  local line=""
  local recent_line_count=0
  local is_error=0

  while IFS= read -r line || [ -n "$line" ]; do
    printf '%s\n' "$(date +%s)" >"$last_output_file"
    printf '%s\n' "$line" >>"$recent_output_file"
    recent_line_count=$((recent_line_count + 1))

    if [ "$recent_line_count" -gt $((CRASH_CONTEXT_LINES * 2)) ]; then
      tail -n "$CRASH_CONTEXT_LINES" "$recent_output_file" >"$recent_output_file.tmp"
      mv "$recent_output_file.tmp" "$recent_output_file"
      recent_line_count="$CRASH_CONTEXT_LINES"
    fi

    is_error=0
    if tilt_line_looks_like_error "$line"; then
      is_error=1
    fi

    if [ "$verbose_mode" -eq 1 ] || [ "$is_error" -eq 1 ]; then
      printf '%s\n' "$line" >&4
    fi

    if [ "$is_error" -eq 1 ]; then
      note_error_output "$error_sequence_file" "$error_output_at_file"
    fi
  done
}

print_failure_context() {
  local exit_status="$1"
  local recent_output_file="$2"
  local error_sequence_file="$3"
  local error_output_at_file="$4"

  [ "$exit_status" -ne 0 ] || return 0
  [ "$shutdown_requested" -eq 0 ] || return 0

  if [ "$verbose" -eq 0 ] && [ -s "$recent_output_file" ]; then
    printf 'flow-localhost: tilt exited with status %s\n' "$exit_status" >&4
    printf 'flow-localhost: recent output follows\n' >&4
    tail -n "$CRASH_CONTEXT_LINES" "$recent_output_file" >&4
  fi

  note_error_output "$error_sequence_file" "$error_output_at_file"
}

forward_signal() {
  local signal="$1"

  shutdown_requested=1

  if [ -n "$server_pid" ]; then
    kill -s "$signal" "$server_pid" 2>/dev/null || true
  fi
}

cleanup_runtime_state() {
  if [ -n "$watcher_pid" ]; then
    kill "$watcher_pid" 2>/dev/null || true
  fi

  if [ -n "$title_updater_pid" ]; then
    kill "$title_updater_pid" 2>/dev/null || true
  fi

  if [ -n "$announcer_pid" ]; then
    kill "$announcer_pid" 2>/dev/null || true
  fi

  if [ -n "$tracker_pid" ]; then
    kill "$tracker_pid" 2>/dev/null || true
  fi

  if [ -n "$runtime_dir" ] && [ -d "$runtime_dir" ]; then
    rm -rf "$runtime_dir"
  fi
}

source_worktree_setup_if_needed() {
  if [ "$repo_root" = "$primary_repo_root" ]; then
    return 0
  fi

  if [ ! -f "$worktree_setup_script" ]; then
    printf 'flow-localhost: missing worktree setup script: %s\n' "$worktree_setup_script" >&2
    exit 1
  fi

  # Worktree runs need the monorepo environment bootstrapped before `applied`.
  # shellcheck disable=SC1090
  source "$worktree_setup_script"
}

source_worktree_setup_if_needed

command -v applied >/dev/null 2>&1 || {
  printf 'flow-localhost: required command not found: applied\n' >&2
  exit 1
}

[ -d "$repo_root/api/tilt" ] && [ -d "$tilt_work_dir" ] || {
  printf 'flow-localhost: run this from the repo root so ./api/outerloop exists\n' >&2
  exit 1
}

kill_existing_flowkit_for_target_dir

port_offset="$(find_free_port_offset)"
tilt_port=$((DEFAULT_TILT_PORT + port_offset))
FLOWKIT_BACKEND_PORT=$((DEFAULT_FLOWKIT_BACKEND_PORT + port_offset))
FLOWKIT_UI_PORT=$((DEFAULT_FLOWKIT_UI_PORT + port_offset))
printf 'starting tilt on http://localhost:%s/\n' "$tilt_port"

export FLOWKIT_BACKEND_PORT
export FLOWKIT_UI_PORT

started_at="$(date +%s)"
runtime_dir="$(mktemp -d "${TMPDIR:-/tmp}/flow-localhost.XXXXXX")"
last_output_file="$runtime_dir/last-output-at"
recent_output_file="$runtime_dir/recent-output.log"
output_pipe="$runtime_dir/tilt-output.pipe"
error_sequence_file="$runtime_dir/error-sequence"
error_output_at_file="$runtime_dir/error-output-at"
error_url_stop_file="$runtime_dir/error-url.stop"
error_url_hold_file="$runtime_dir/error-url.hold"
mkfifo "$output_pipe"
printf '%s\n' "$started_at" >"$last_output_file"
: >"$recent_output_file"
printf '0\n' >"$error_sequence_file"
printf '0\n' >"$error_output_at_file"

# Preserve the user's stdout/stderr so the readiness watcher can print after
# tilt output goes quiet, while the tracker keeps a short tail for crash dumps.
exec 3>&1
exec 4>&2
trap cleanup_runtime_state EXIT
trap 'forward_signal INT' INT
trap 'forward_signal TERM' TERM

set_terminal_title "$FLOWKIT_UI_PORT" "$repo_root"
update_terminal_title_loop "$FLOWKIT_UI_PORT" "$repo_root" &
title_updater_pid="$!"

announce_frontend_url_after_errors "$FLOWKIT_UI_PORT" "$error_sequence_file" "$error_output_at_file" "$error_url_stop_file" "$error_url_hold_file" &
announcer_pid="$!"

track_tilt_output "$last_output_file" "$recent_output_file" "$verbose" "$error_sequence_file" "$error_output_at_file" <"$output_pipe" &
tracker_pid="$!"

cd "$tilt_work_dir"
applied tilt up flowkit --port "$tilt_port" >"$output_pipe" 2>&1 &
server_pid="$!"

announce_when_frontend_is_ready "$FLOWKIT_UI_PORT" "$server_pid" "$started_at" "$last_output_file" &
watcher_pid="$!"

set +e
wait "$server_pid"
exit_status="$?"

if [ "$exit_status" -ne 0 ]; then
  : >"$error_url_hold_file"
  kill "$watcher_pid" 2>/dev/null || true
fi

wait "$tracker_pid"
wait "$watcher_pid"
set -e

print_failure_context "$exit_status" "$recent_output_file" "$error_sequence_file" "$error_output_at_file"
rm -f "$error_url_hold_file"
: >"$error_url_stop_file"

set +e
wait "$announcer_pid"
set -e

exit "$exit_status"
