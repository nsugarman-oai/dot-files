#!/usr/bin/env bash
set -euo pipefail

script_name="${0##*/}"

usage() {
  printf 'Usage: %s\n' "$script_name"
  printf 'Kills Workstreams listeners on ports 4010, 4011, 5203, and 5204 when their cwd matches workstreams.\n'
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

if [ "$#" -gt 0 ]; then
  usage >&2
  exit 1
fi

matches="$(
  for port in 4010 4011 5203 5204; do
    pids="$(lsof -nP -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
    [ -n "$pids" ] || continue

    while IFS= read -r pid; do
      [ -n "$pid" ] || continue

      process_info="$(lsof -a -p "$pid" -d cwd -Fgn 2>/dev/null || true)"
      cwd="$(printf '%s\n' "$process_info" | awk '/^n/ { print substr($0, 2); exit }')"
      case "$cwd" in
        *work-streams*|*workstreams*)
          pgid="$(printf '%s\n' "$process_info" | awk '/^g/ { print substr($0, 2); exit }')"
          [ -n "$pgid" ] || continue
          printf 'pgid:%s\n' "$pgid"
          printf 'port:%s\n' "$port"
          ;;
      esac
    done <<< "$pids"
  done | sort -u
)"

pgids="$(printf '%s\n' "$matches" | awk -F: '/^pgid:/ { print $2 }')"
[ -n "$pgids" ] || exit 0

ports="$(printf '%s\n' "$matches" | awk -F: '/^port:/ { print $2 }')"

while IFS= read -r pgid; do
  [ -n "$pgid" ] || continue
  kill -KILL -- "-$pgid" 2>/dev/null || true
done <<< "$pgids"

if [ -n "$ports" ]; then
  printf 'killed workstreams ports:\n%s\n' "$ports"
fi
