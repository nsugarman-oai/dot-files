#!/usr/bin/env bash
set -euo pipefail

FLOWKIT_BACKEND_PORT=8081
FLOWKIT_UI_PORT=5173
DEFAULT_TILT_PORT=10350

current_dir="$(pwd -P)"

port_is_taken() {
  local port="$1"
  lsof -tiTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

frontend_is_ready() {
  local port="$1"

  if command -v curl >/dev/null 2>&1; then
    curl --silent --fail --max-time 1 "http://127.0.0.1:$port/" >/dev/null 2>&1
    return
  fi

  port_is_taken "$port"
}

find_checkout_root() {
  local dir="$current_dir"

  while [ "$dir" != "/" ]; do
    if [ -d "$dir/api/outerloop" ] && [ -d "$dir/api/tilt" ]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done

  return 1
}

path_is_within() {
  local candidate="${1%/}"
  local root="${2%/}"

  [ "$candidate" = "$root" ] || [[ "$candidate/" == "$root/"* ]]
}

pid_cwd() {
  local pid="$1"

  lsof -a -d cwd -p "$pid" -Fn 2>/dev/null | awk '
    /^n/ {
      print substr($0, 2)
      exit
    }
  '
}

pid_command() {
  local pid="$1"

  ps -o command= -p "$pid" 2>/dev/null || true
}

tilt_pgids_for_current_dir() {
  local pid pgid cwd

  while IFS='|' read -r pid pgid; do
    [ -n "$pid" ] || continue

    cwd="$(pid_cwd "$pid")"
    [ "$cwd" = "$current_dir" ] || continue

    printf '%s\n' "$pgid"
  done < <(
    ps -axo pid=,pgid=,command= | awk '
      /\/tilt up flowkit( --port [0-9]+)?$/ {
        print $1 "|" $2
      }
    '
  )
}

flowkit_service_pgid_for_port() {
  local port="$1"
  local checkout_root="$2"
  local pid pgid cwd command

  lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null | while IFS= read -r pid; do
    [ -n "$pid" ] || continue

    cwd="$(pid_cwd "$pid")"
    if [ -z "$cwd" ] || ! path_is_within "$cwd" "$checkout_root"; then
      continue
    fi

    command="$(pid_command "$pid")"
    case "$command" in
      *"uvicorn flowkit.asgi:application"*|*"/api/outerloop/flowkit_ui/"*"vite/bin/vite.js --port"*)
        pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ')"
        [ -n "$pgid" ] || continue
        printf '%s\n' "$pgid"
        ;;
    esac
  done
}

kill_existing_flowkit_for_current_dir() {
  local checkout_root=""
  local tilt_pgids=""
  local pgids=""
  local pgid

  tilt_pgids="$(tilt_pgids_for_current_dir)"
  [ -n "$tilt_pgids" ] || return 0

  pgids="$tilt_pgids"
  if checkout_root="$(find_checkout_root)"; then
    pgids="$pgids"$'\n'"$(flowkit_service_pgid_for_port "$FLOWKIT_BACKEND_PORT" "$checkout_root")"
    pgids="$pgids"$'\n'"$(flowkit_service_pgid_for_port "$FLOWKIT_UI_PORT" "$checkout_root")"
  fi

  pgids="$(printf '%s\n' "$pgids" | tr -d ' ' | sed '/^$/d' | sort -u)"
  [ -n "$pgids" ] || return 0

  while IFS= read -r pgid; do
    kill -TERM -- "-$pgid" 2>/dev/null || true
  done < <(printf '%s\n' "$pgids")

  sleep 1

  while IFS= read -r pgid; do
    kill -0 -- "-$pgid" 2>/dev/null || continue
    kill -KILL -- "-$pgid" 2>/dev/null || true
  done < <(printf '%s\n' "$pgids")
}

find_free_tilt_port() {
  local port="$DEFAULT_TILT_PORT"

  while port_is_taken "$port"; do
    port=$((port + 1))
  done

  printf '%s\n' "$port"
}

announce_when_frontend_is_ready() {
  local port="$1"
  local server_pid="$2"

  while true; do
    if frontend_is_ready "$port"; then
      printf 'running flowkit on http://localhost:%s/\n' "$port"
      return 0
    fi

    if ! kill -0 "$server_pid" 2>/dev/null; then
      return 1
    fi

    sleep 1
  done
}

command -v applied >/dev/null 2>&1 || {
  printf 'flowkit-localhost: required command not found: applied\n' >&2
  exit 1
}

kill_existing_flowkit_for_current_dir

tilt_port="$(find_free_tilt_port)"

export FLOWKIT_BACKEND_PORT
export FLOWKIT_UI_PORT

# This watcher survives the exec below and prints the single ready line once
# the frontend answers on localhost.
announce_when_frontend_is_ready "$FLOWKIT_UI_PORT" "$$" &
exec applied tilt up flowkit --port "$tilt_port"
