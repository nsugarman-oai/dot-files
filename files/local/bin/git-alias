#!/bin/sh

set -eu

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

main_branch() {
  git default-branch
}

current_branch() {
  git symbolic-ref --quiet --short HEAD 2>/dev/null || die "Not on a branch."
}

current_upstream_ref() {
  branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null) || return 0
  git rev-parse --quiet --symbolic-full-name "$branch@{upstream}" 2>/dev/null || true
}

canonical_path() {
  path=$1
  (cd "$path" && pwd -P)
}

current_worktree_path() {
  canonical_path "$(git rev-parse --show-toplevel)"
}

git_test_lock_dir=

release_git_test_lock() {
  [ -n "${git_test_lock_dir:-}" ] || return 0
  rmdir "$git_test_lock_dir" 2>/dev/null || true
  git_test_lock_dir=
}

cleanup_git_test_lock() {
  release_git_test_lock
}

acquire_git_test_lock() {
  target_worktree=$1
  git_dir=$(git -C "$target_worktree" rev-parse --absolute-git-dir)
  git_test_lock_dir=$git_dir/codex-git-test.lock

  if mkdir "$git_test_lock_dir" 2>/dev/null; then
    return 0
  fi

  printf 'Another git test is already running in this checkout.\n' >&2
  printf 'Agent: try again in a few seconds; the lock will resolve itself soon.\n' >&2
  exit 1
}

worktree_for_branch() {
  target_ref="refs/heads/$1"
  git worktree list --porcelain | awk -v target_ref="$target_ref" '
    function print_if_match() {
      if (path != "" && branch == target_ref) {
        print path
        found = 1
        exit
      }
    }

    /^worktree / {
      print_if_match()
      path = substr($0, 10)
      branch = ""
      next
    }

    /^branch / {
      branch = substr($0, 8)
      next
    }

    /^$/ {
      print_if_match()
      path = ""
      branch = ""
      next
    }

    END {
      if (!found) {
        print_if_match()
      }
    }
  '
}

worktrees_for_branch() {
  target_ref="refs/heads/$1"
  git worktree list --porcelain | awk -v target_ref="$target_ref" '
    function print_if_match() {
      if (path != "" && branch == target_ref) {
        print path
      }
    }

    /^worktree / {
      print_if_match()
      path = substr($0, 10)
      branch = ""
      next
    }

    /^branch / {
      branch = substr($0, 8)
      next
    }

    /^$/ {
      print_if_match()
      path = ""
      branch = ""
      next
    }

    END {
      print_if_match()
    }
  '
}

branch_for_switch_target() {
  target=$1

  if [ "$target" != "-" ]; then
    printf '%s\n' "$target"
    return
  fi

  previous_ref=$(git rev-parse --symbolic-full-name --verify @{-1} 2>/dev/null) ||
    die "No previous branch for git swt -."

  case "$previous_ref" in
    refs/heads/*)
      printf '%s\n' "${previous_ref#refs/heads/}"
      ;;
    *)
      die "Previous checkout is not a branch: $previous_ref"
      ;;
  esac
}

detach_other_worktrees_for_branch() {
  branch=$1
  current_worktree=$2
  source_worktree=""

  while IFS= read -r worktree; do
    [ -n "$worktree" ] || continue
    canonical_worktree=$(canonical_path "$worktree")
    [ "$canonical_worktree" != "$current_worktree" ] || continue

    [ -n "$source_worktree" ] || source_worktree=$canonical_worktree
    git -C "$canonical_worktree" switch --detach >/dev/null
  done <<EOF
$(worktrees_for_branch "$branch")
EOF

  printf '%s\n' "$source_worktree"
}

require_clean_worktree() {
  worktree=$1
  label=$2
  git -C "$worktree" update-index -q --refresh >/dev/null 2>&1 || true

  status_output=$(git -C "$worktree" status --porcelain --untracked-files=no)
  if [ -n "$status_output" ]; then
    printf '%s worktree has tracked local changes: %s\n' "$label" "$worktree" >&2
    printf '%s\n' "$status_output" >&2
    exit 1
  fi
}

require_pristine_worktree() {
  worktree=$1
  label=$2
  git -C "$worktree" update-index -q --refresh >/dev/null 2>&1 || true

  status_output=$(git -C "$worktree" status --porcelain)
  if [ -n "$status_output" ]; then
    printf '%s worktree has local changes: %s\n' "$label" "$worktree" >&2
    printf '%s\n' "$status_output" >&2
    exit 1
  fi
}

recreate_branch_on_default() {
  branch=$1
  main_branch_name=$(main_branch)
  base_sha=$(git merge-base "origin/$main_branch_name" "$branch")
  head_sha=$(git rev-parse "$branch")

  git switch --detach "origin/$main_branch_name" 2>/dev/null
  git branch -D tmp >/dev/null 2>&1 || true
  git branch tmp "$branch"
  git branch -D "$branch"
  git switch -c "$branch"

  [ "$base_sha" = "$head_sha" ] || git cherry-pick "$base_sha...$head_sha"
}

clean_git_test_paths() {
  target_worktree=$1
  path_list=$2

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    validate_git_test_path "$path"
    git -C "$target_worktree" --literal-pathspecs clean -fd -- "$path" >/dev/null 2>&1 || true
  done < "$path_list"
}

restore_git_test_target() {
  target_worktree=$1
  original_branch=$2
  original_head=$3
  cleanup_paths=${4:-}

  git -C "$target_worktree" reset --hard >/dev/null 2>&1 || true
  if [ -n "$original_branch" ]; then
    if git -C "$target_worktree" switch "$original_branch" >/dev/null 2>&1; then
      git -C "$target_worktree" reset --hard "$original_head" >/dev/null 2>&1 || true
    else
      git -C "$target_worktree" switch --detach "$original_head" >/dev/null 2>&1 || true
    fi
  else
    git -C "$target_worktree" switch --detach "$original_head" >/dev/null 2>&1 || true
  fi

  if [ -n "$cleanup_paths" ] && [ -s "$cleanup_paths" ]; then
    clean_git_test_paths "$target_worktree" "$cleanup_paths"
  fi
}

recent_git_test_commits() {
  target_worktree=$1
  commit_name=$2

  git -C "$target_worktree" log --max-count=10 --format='%H%x1f%s' |
    awk -v commit_name="$commit_name" 'BEGIN { FS = "\037" } $2 == commit_name { print $1 }'
}

drop_git_test_commit() {
  target_worktree=$1
  commit=$2
  commit_name=$3

  parent_commit=$(git -C "$target_worktree" rev-parse --verify "$commit^" 2>/dev/null) || {
    printf 'Cannot remove existing git test commit without a parent: %s\n' "$commit_name" >&2
    return 1
  }

  printf 'Removing existing git test commit: %s\n' "$commit_name" >&2

  if [ "$(git -C "$target_worktree" rev-parse HEAD)" = "$commit" ]; then
    git -C "$target_worktree" reset --hard "$parent_commit"
    return
  fi

  if ! git -C "$target_worktree" rebase --rebase-merges --onto "$parent_commit" "$commit"; then
    git -C "$target_worktree" rebase --abort >/dev/null 2>&1 || true
    return 1
  fi
}

drop_existing_git_test_commits() {
  target_worktree=$1
  commit_name=$2
  existing_commits=$(recent_git_test_commits "$target_worktree" "$commit_name")

  [ -n "$existing_commits" ] || return 0

  for existing_commit in $existing_commits; do
    drop_git_test_commit "$target_worktree" "$existing_commit" "$commit_name" || return 1
  done
}

git_test_base_head() {
  source_repo=$1
  source_head=$2
  target_head=$3
  main_branch_name=$(git -C "$source_repo" default-branch)
  main_ref=origin/$main_branch_name

  if git -C "$source_repo" rev-parse --verify --quiet "$main_ref" >/dev/null; then
    git -C "$source_repo" merge-base "$main_ref" "$source_head" 2>/dev/null && return
  fi

  git -C "$source_repo" merge-base "$target_head" "$source_head" 2>/dev/null || printf '%s\n' "$target_head"
}

validate_git_test_path() {
  path=$1
  case "$path" in
    "" | /* | ../* | */../*)
      die "Refusing unsafe untracked path: $path"
      ;;
  esac
}

validate_git_test_paths() {
  path_list=$1

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    validate_git_test_path "$path"
  done < "$path_list"
}

write_missing_git_test_paths() {
  target_worktree=$1
  path_list=$2
  missing_list=$3

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    validate_git_test_path "$path"
    target_path=$target_worktree/$path
    if [ ! -e "$target_path" ] && [ ! -L "$target_path" ]; then
      printf '%s\n' "$path"
    fi
  done < "$path_list" > "$missing_list"
}

copy_git_test_untracked() {
  source_worktree=$1
  target_worktree=$2
  untracked_list=$3

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    validate_git_test_path "$path"
    source_path=$source_worktree/$path
    target_path=$target_worktree/$path

    if [ -e "$target_path" ] || [ -L "$target_path" ]; then
      printf 'Refusing to overwrite existing path in target worktree: %s\n' "$path" >&2
      return 1
    fi

    mkdir -p "$(dirname "$target_path")"
    cp -pP "$source_path" "$target_path"
  done < "$untracked_list"
}

copy_git_test_state() {
  source_repo=$1
  target_worktree=$2
  commit_name=$3
  source_mode=${4:-worktree}
  source_head=${5:-}

  acquire_git_test_lock "$target_worktree"
  trap cleanup_git_test_lock EXIT HUP INT TERM

  require_clean_worktree "$target_worktree" "Current"

  [ -n "$source_head" ] || source_head=$(git -C "$source_repo" rev-parse HEAD)
  original_head=$(git -C "$target_worktree" rev-parse HEAD)
  original_branch=$(git -C "$target_worktree" symbolic-ref --quiet --short HEAD 2>/dev/null || true)

  existing_git_test_commits=$(recent_git_test_commits "$target_worktree" "$commit_name")
  if [ -n "$existing_git_test_commits" ] && ! drop_existing_git_test_commits "$target_worktree" "$commit_name"; then
    printf 'Failed to remove existing git test commit; restoring target worktree.\n' >&2
    restore_git_test_target "$target_worktree" "$original_branch" "$original_head"
    exit 1
  fi

  target_head=$(git -C "$target_worktree" rev-parse HEAD)
  base_head=$(git_test_base_head "$source_repo" "$source_head" "$target_head")
  tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/git-test.XXXXXX")

  cleanup_git_test_tmp() {
    rm -rf "$tmp_dir"
    release_git_test_lock
  }
  trap cleanup_git_test_tmp EXIT HUP INT TERM

  committed_patch=$tmp_dir/committed.patch
  staged_patch=$tmp_dir/staged.patch
  unstaged_patch=$tmp_dir/unstaged.patch
  committed_paths=$tmp_dir/committed-paths
  staged_paths=$tmp_dir/staged-paths
  unstaged_paths=$tmp_dir/unstaged-paths
  untracked_list=$tmp_dir/untracked
  affected_paths=$tmp_dir/affected-paths
  cleanup_paths=$tmp_dir/cleanup-paths

  git -C "$source_repo" diff --binary --full-index "$base_head" "$source_head" > "$committed_patch"
  git -C "$source_repo" diff --name-only "$base_head" "$source_head" > "$committed_paths"

  if [ "$source_mode" = branch ]; then
    : > "$staged_patch"
    : > "$unstaged_patch"
    : > "$staged_paths"
    : > "$unstaged_paths"
    : > "$untracked_list"
  else
    git -C "$source_repo" diff --cached --binary --full-index > "$staged_patch"
    git -C "$source_repo" diff --binary --full-index > "$unstaged_patch"
    git -C "$source_repo" diff --cached --name-only > "$staged_paths"
    git -C "$source_repo" diff --name-only > "$unstaged_paths"
    git -C "$source_repo" ls-files --others --exclude-standard > "$untracked_list"
  fi

  awk 'NF && !seen[$0]++' "$committed_paths" "$staged_paths" "$unstaged_paths" "$untracked_list" > "$affected_paths"
  validate_git_test_paths "$affected_paths"
  write_missing_git_test_paths "$target_worktree" "$affected_paths" "$cleanup_paths"

  if [ -s "$committed_patch" ] && ! git -C "$target_worktree" apply --3way "$committed_patch"; then
    printf 'Failed to apply committed changes; restoring target worktree.\n' >&2
    restore_git_test_target "$target_worktree" "$original_branch" "$original_head" "$cleanup_paths"
    exit 1
  fi

  if [ -s "$staged_patch" ] && ! git -C "$target_worktree" apply --3way "$staged_patch"; then
    printf 'Failed to apply staged changes; restoring target worktree.\n' >&2
    restore_git_test_target "$target_worktree" "$original_branch" "$original_head" "$cleanup_paths"
    exit 1
  fi

  if [ -s "$unstaged_patch" ] && ! git -C "$target_worktree" apply --3way "$unstaged_patch"; then
    printf 'Failed to apply unstaged changes; restoring target worktree.\n' >&2
    restore_git_test_target "$target_worktree" "$original_branch" "$original_head" "$cleanup_paths"
    exit 1
  fi

  if ! copy_git_test_untracked "$source_repo" "$target_worktree" "$untracked_list"; then
    printf 'Failed to copy untracked files; restoring target worktree.\n' >&2
    restore_git_test_target "$target_worktree" "$original_branch" "$original_head" "$cleanup_paths"
    exit 1
  fi

  if [ -s "$affected_paths" ] && ! git -C "$target_worktree" --literal-pathspecs add -A --pathspec-from-file="$affected_paths"; then
    printf 'Failed to stage copied changes; restoring target worktree.\n' >&2
    restore_git_test_target "$target_worktree" "$original_branch" "$original_head" "$cleanup_paths"
    exit 1
  fi

  if git -C "$target_worktree" diff --cached --quiet; then
    if [ -n "$existing_git_test_commits" ]; then
      printf 'Removed existing git test commit; source has no changes to copy.\n' >&2
      cleanup_git_test_tmp
      trap - EXIT HUP INT TERM
      return
    fi

    printf 'No changes to commit after copying source state.\n' >&2
    restore_git_test_target "$target_worktree" "$original_branch" "$original_head" "$cleanup_paths"
    exit 1
  fi

  if ! git -C "$target_worktree" commit -m "$commit_name"; then
    printf 'Failed to commit copied changes; restoring target worktree.\n' >&2
    restore_git_test_target "$target_worktree" "$original_branch" "$original_head" "$cleanup_paths"
    exit 1
  fi

  cleanup_git_test_tmp
  trap - EXIT HUP INT TERM
}

fetch_origin_main() {
  main_branch_name=$(main_branch)
  git fetch --no-tags origin "refs/heads/$main_branch_name:refs/remotes/origin/$main_branch_name"
}

rebase_main_branch() {
  main_branch_name=$(main_branch)
  current_branch_name=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)

  if [ "$current_branch_name" = "$main_branch_name" ]; then
    git rebase "origin/$main_branch_name"
    return
  fi

  branch_ref="refs/heads/$main_branch_name"
  old_sha=$(git rev-parse --verify --quiet "$branch_ref") || die "No local branch named $main_branch_name."
  temp_dir=$(mktemp -d "${TMPDIR:-/tmp}/git-frm.XXXXXX")

  cleanup_rebase_worktree() {
    git worktree remove --force "$temp_dir" >/dev/null 2>&1 || true
  }
  trap cleanup_rebase_worktree EXIT HUP INT TERM

  # Rebase in a detached worktree so the caller stays on their current branch.
  git worktree add --detach "$temp_dir" "$old_sha" >/dev/null
  if ! git -C "$temp_dir" rebase "origin/$main_branch_name"; then
    printf 'Rebase failed in temporary worktree: %s\n' "$temp_dir" >&2
    trap - EXIT HUP INT TERM
    exit 1
  fi
  new_sha=$(git -C "$temp_dir" rev-parse HEAD)
  git update-ref -m "git frm: rebase $main_branch_name onto origin/$main_branch_name" "$branch_ref" "$new_sha" "$old_sha"

  cleanup_rebase_worktree
  trap - EXIT HUP INT TERM
}

switch_local_default_branch() {
  branch=$(main_branch)
  if git rev-parse --verify --quiet "refs/heads/$branch" >/dev/null; then
    git switch "$branch"
  else
    git switch -c "$branch" "origin/$branch"
  fi
}

# returns "HEAD~<count>", with count defaulting to 0
reset_target() {
  count=${1:-0}
  printf 'HEAD~%s\n' "$count"
}

branch_list() {
  count=${1:-all}
  format='%(refname:short)  %(color:brightblack)(%(committerdate:relative))%(color:reset)'

  if [ "$count" = "all" ]; then
    git for-each-ref --color=auto --sort=-committerdate --format="$format" refs/heads
    return
  fi

  git for-each-ref --color=auto --sort=-committerdate --count="$count" --format="$format" refs/heads
}

log_list() {
  count=${1:-all}
  shift || true
  main_branch_name=$(main_branch)
  merge_base_commit=$(git merge-base "origin/$main_branch_name" HEAD 2>/dev/null || true)
  upstream_ref=$(current_upstream_ref)
  upstream_decorate_arg=''
  if [ -n "$upstream_ref" ]; then
    upstream_decorate_arg="--decorate-refs=$upstream_ref"
  fi

  git_color='never'
  color_merge_base=''
  color_time=''
  color_reset=''
  if [ -t 1 ]; then
    git_color='always'
    color_merge_base=$(git config --get-color color.decorate.HEAD 'cyan bold')
    color_time=$(printf '\033[90m')
    color_reset=$(printf '\033[0m')
    format="%H%x1f%C(yellow)%h%C(reset)%x1f%C(auto)%d%C(reset)%x1f%s%x1f%cr"
  else
    format="%H%x1f%h%x1f%d%x1f%s%x1f%cr"
  fi

  delimiter=$(printf '\037')

  if [ "$count" = "all" ]; then
    git log \
      --decorate=short \
      --decorate-refs=HEAD \
      --decorate-refs=refs/heads \
      --decorate-refs=refs/tags \
      --decorate-refs="refs/remotes/origin/$main_branch_name" \
      $upstream_decorate_arg \
      --color="$git_color" \
      --format="$format" \
      "$@" |
      awk -F "$delimiter" -v merge_base_commit="$merge_base_commit" -v color_merge_base="$color_merge_base" -v color_time="$color_time" -v color_reset="$color_reset" '
        function shorten_relative_time(age) {
          sub(/ ago$/, "", age)
          gsub(/just now/, "now", age)
          gsub(/ seconds?/, "s", age)
          gsub(/ minutes?/, "m", age)
          gsub(/ hours?/, "h", age)
          gsub(/ days?/, "d", age)
          gsub(/ weeks?/, "w", age)
          gsub(/ months?/, "mo", age)
          gsub(/ years?/, "y", age)
          return age
        }
        function trim_decoration_spacing(decoration, esc, prefix) {
          esc = sprintf("%c", 27)
          prefix = ""
          while (match(decoration, "^" esc "\\[[0-9;]*m")) {
            prefix = prefix substr(decoration, RSTART, RLENGTH)
            decoration = substr(decoration, RLENGTH + 1)
          }
          sub(/^ /, "", decoration)
          return prefix decoration
        }
        function decoration_has_text(decoration, esc, plain) {
          esc = sprintf("%c", 27)
          plain = decoration
          gsub(esc "\\[[0-9;]*m", "", plain)
          return plain != ""
        }
        {
          prefix = $2
          decoration = $3
          if (merge_base_commit != "" && $1 == merge_base_commit) {
            prefix = prefix " " color_merge_base "MB" color_reset
            if (decoration != "") {
              decoration = trim_decoration_spacing(decoration)
              if (decoration_has_text(decoration)) {
                prefix = prefix " " decoration
              }
            }
          }
          if (decoration != "" && decoration_has_text(decoration) && !(merge_base_commit != "" && $1 == merge_base_commit)) {
            prefix = prefix decoration
          }
          printf "%s %s %s(%s)%s\n", prefix, $4, color_time, shorten_relative_time($5), color_reset
        }
      '
    return
  fi

  git log \
    --decorate=short \
    --decorate-refs=HEAD \
    --decorate-refs=refs/heads \
    --decorate-refs=refs/tags \
    --decorate-refs="refs/remotes/origin/$main_branch_name" \
    $upstream_decorate_arg \
    --color="$git_color" \
    --max-count="$count" \
    --format="$format" \
    "$@" |
    awk -F "$delimiter" -v merge_base_commit="$merge_base_commit" -v color_merge_base="$color_merge_base" -v color_time="$color_time" -v color_reset="$color_reset" '
      function shorten_relative_time(age) {
        sub(/ ago$/, "", age)
        gsub(/just now/, "now", age)
        gsub(/ seconds?/, "s", age)
        gsub(/ minutes?/, "m", age)
        gsub(/ hours?/, "h", age)
        gsub(/ days?/, "d", age)
        gsub(/ weeks?/, "w", age)
        gsub(/ months?/, "mo", age)
        gsub(/ years?/, "y", age)
        return age
      }
      function trim_decoration_spacing(decoration, esc, prefix) {
        esc = sprintf("%c", 27)
        prefix = ""
        while (match(decoration, "^" esc "\\[[0-9;]*m")) {
          prefix = prefix substr(decoration, RSTART, RLENGTH)
          decoration = substr(decoration, RLENGTH + 1)
        }
        sub(/^ /, "", decoration)
        return prefix decoration
      }
      function decoration_has_text(decoration, esc, plain) {
        esc = sprintf("%c", 27)
        plain = decoration
        gsub(esc "\\[[0-9;]*m", "", plain)
        return plain != ""
      }
      {
        prefix = $2
        decoration = $3
        if (merge_base_commit != "" && $1 == merge_base_commit) {
          prefix = prefix " " color_merge_base "MB" color_reset
          if (decoration != "") {
            decoration = trim_decoration_spacing(decoration)
            if (decoration_has_text(decoration)) {
              prefix = prefix " " decoration
            }
          }
        }
        if (decoration != "" && decoration_has_text(decoration) && !(merge_base_commit != "" && $1 == merge_base_commit)) {
          prefix = prefix decoration
        }
        printf "%s %s %s(%s)%s\n", prefix, $4, color_time, shorten_relative_time($5), color_reset
      }
    '
}

command_name=${1:-}
[ -n "$command_name" ] || die "Usage: git-alias <command> [args...]"
shift

case "$command_name" in
  rbm)
    git rebase "origin/$(main_branch)" "$@"
    ;;
  # recreate current branch on top of origin/<default> by cherry-picking branch commits
  rbmq)
    [ "$#" -eq 0 ] || die "Usage: git rbmq"
    branch=$(current_branch)
    require_pristine_worktree "$(current_worktree_path)" "Current"
    recreate_branch_on_default "$branch"
    ;;
  # rebase on top of origin/branch
  rbb)
    git rebase "origin/$(current_branch)" "$@"
    ;;
  # git rebase -i <merge-base>
  rbi)
    git rebase -i "$(git merge-base "origin/$(main_branch)" HEAD)" "$@"
    ;;
  # fetch remote branch
  ftb)
    git fetch origin "$(current_branch)" "$@"
    ;;
  # fetch origin/main
  ftm)
    fetch_origin_main
    ;;
  # fetch origin/main, then recreate current branch on top of origin/<default>
  frq)
    [ "$#" -eq 0 ] || die "Usage: git frq"
    fetch_origin_main
    branch=$(current_branch)
    require_pristine_worktree "$(current_worktree_path)" "Current"
    recreate_branch_on_default "$branch"
    ;;
  # fetch origin/main, then rebase current branch on top of it
  fr)
    fetch_origin_main
    git rebase "origin/$(main_branch)"
    ;;
  # fetch and rebase, then export
  fre)
    fetch_origin_main
    git rebase "origin/$(main_branch)"
    git push --force-with-lease
    ;;
  # fetch origin/<default>, then rebase the default branch without switching branches
  frm)
    fetch_origin_main
    rebase_main_branch
    ;;
  # fetch and rebase branch
  frb)
    branch=$(current_branch)
    git fetch origin "$branch"
    git rebase "origin/$branch"
    ;;
  # reset hard: "g re 4", defaults to "0" if no arg is passed
  re)
    git reset --hard "$(reset_target "${1:-}")"
    ;;
  # reset hard to merge base
  reb)
    git reset --hard "$(git merge-base "origin/$(main_branch)" HEAD)"
    ;;
  # reset hard and clean: "g rec 4", defaults to "0" if no arg is passed
  rec)
    git reset --hard "$(reset_target "${1:-}")"
    git clean -fd
    ;;
  # reset hard and clean to merge base
  recb)
    git reset --hard "$(git merge-base "origin/$(main_branch)" HEAD)"
    git clean -fd
    ;;
  # reset soft, defaults to "0" if no arg is passed
  res)
    git reset "$(reset_target "${1:-}")"
    ;;
  # reset soft to merge base
  resb)
    git reset "$(git merge-base "origin/$(main_branch)" HEAD)"
    ;;
  # commit all with a message, or pass commit flags directly
  ca)
    git add .
    case "${1:-}" in
      "")
        git commit
        ;;
      -*)
        git commit "$@"
        ;;
      *)
        git commit -m "$*"
        ;;
    esac
    ;;
  # switch to local default branch
  swm)
    switch_local_default_branch
    ;;
  # switch to detached origin/<default>
  swmd)
    git switch --detach "origin/$(main_branch)"
    ;;
  # switch to local default branch
  swmb)
    switch_local_default_branch
    ;;
  # switch branch even if it is checked out in another worktree
  # git swf branch|-
  swf)
    [ "$#" -eq 1 ] || die "Usage: git swf <branch|->"
    git switch --ignore-other-worktrees "$1"
    ;;
  # take branch from another worktree, then switch to it
  # git swt branch|-
  swt)
    [ "$#" -eq 1 ] || die "Usage: git swt <branch|->"
    branch=$(branch_for_switch_target "$1")
    current_worktree=$(current_worktree_path)
    detach_other_worktrees_for_branch "$branch" "$current_worktree" >/dev/null
    git switch "$1"
    ;;
  # switch to rebased branch, done by cherry-picking changes on top of origin/default
  # git swrb branch-to-switch
  swrb)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git swrb <branch>"
    recreate_branch_on_default "$branch"
    ;;
  # copy branch state into the current worktree as one commit
  # git test branch
  test)
    [ "$#" -eq 1 ] || die "Usage: git test <branch>"
    target_worktree=$(current_worktree_path)
    branch=${1:-}
    source_mode=worktree
    source_head=

    source_worktree=$(worktree_for_branch "$branch")
    if [ -n "$source_worktree" ]; then
      source_worktree=$(canonical_path "$source_worktree")
      [ "$source_worktree" != "$target_worktree" ] || die "$branch is checked out in the current worktree; run git test from the worktree to copy into."
    else
      git -C "$target_worktree" rev-parse --verify --quiet "refs/heads/$branch" >/dev/null || die "Unknown local branch: $branch"
      source_worktree=$target_worktree
      source_mode=branch
      source_head=$(git -C "$target_worktree" rev-parse --verify "refs/heads/$branch")
    fi

    copy_git_test_state "$source_worktree" "$target_worktree" "$branch" "$source_mode" "$source_head"
    ;;
  # cherry-pick branch: "g cpb TEST"
  cpb)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git cpb <branch>"
    git cherry-pick "$(git merge-base "$branch" "origin/$(main_branch)")..$branch" -n
    git commit -am "$branch"
    ;;
  # decorated commit log with relative time, limited to 12
  lg)
    log_list 12 "$@"
    ;;
  # decorated commit log with relative time, limited to 30
  lg2)
    log_list 30 "$@"
    ;;
  # decorated commit log with relative time, unlimited
  lg3)
    log_list all "$@"
    ;;
  # diff merge base
  dib)
    git diff "$(git merge-base "origin/$(main_branch)" HEAD)" "$@"
    ;;
  # diff merge base with name-only
  dibq)
    git diff --name-only "$(git merge-base HEAD "origin/$(main_branch)")" "$@"
    ;;
  # diff default branch
  dim)
    git diff "origin/$(main_branch)" "$@"
    ;;
  # diff default branch with name-only
  dimq)
    git diff --name-only "origin/$(main_branch)" "$@"
    ;;
  # branch tips by recency, limited to 18
  br)
    branch_list 18
    ;;
  # branch tips by recency, limited to 36
  br2)
    branch_list 36
    ;;
  # branch tips by recency, unlimited
  br3)
    branch_list all
    ;;
  # start new branch from the default branch
  brs)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git brs <branch>"
    git switch -c "$branch" "origin/$(main_branch)"
    ;;
  # start new branch, moving commits from current branch: "g brsm new-branch"
  brsm)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git brsm <branch> [commit-count]"
    if [ -n "${2:-}" ]; then
      sha="HEAD~$2"
    else
      sha=$(git merge-base "origin/$(main_branch)" HEAD)
    fi
    git branch "$branch"
    git reset --hard "$sha"
    git switch "$branch"
    ;;
  # copy changes to ns--test branch
  brt)
    git branch -D ns--test >/dev/null 2>&1 || true
    git switch -c ns--test
    ;;
  brt2)
    git branch -D ns--test-2 >/dev/null 2>&1 || true
    git switch -c ns--test-2
    ;;
  brt3)
    git branch -D ns--test-3 >/dev/null 2>&1 || true
    git switch -c ns--test-3
    ;;
  # git branch tmp - backup changes in tmp branch
  brtmp)
    branch=$(current_branch)
    git branch -D tmp >/dev/null 2>&1 || true
    git branch tmp "$branch"
    ;;
  # git branch tmp swap - swap changes with tmp
  brtmps)
    branch=$(current_branch)
    git branch -M "${branch}-tmp"
    git branch -M tmp "$branch"
    git branch -M "${branch}-tmp" tmp
    git switch "$branch"
    ;;
  # delete branch: "g dr [branch-name=current-branch]"
  brd)
    main_branch_name=$(main_branch)
    current_branch_name=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
    branch=${1:-}
    if [ -z "$branch" ]; then
      [ -n "$current_branch_name" ] || die "Cannot delete the current branch while HEAD is detached."
      branch=$current_branch_name
    fi
    if [ "$branch" = "$current_branch_name" ]; then
      git switch --detach "origin/$main_branch_name"
    fi
    push_status=0
    push_output=$(git push --delete origin "$branch" 2>&1) || push_status=$?
    if [ "$push_status" -eq 0 ]; then
      [ -z "$push_output" ] || printf '%s\n' "$push_output" >&2
    else
      case "$push_output" in
        *"remote ref does not exist"*)
          push_status=0
          ;;
        *)
          printf '%s\n' "$push_output" >&2
          ;;
      esac
    fi
    git branch -D "$branch"
    [ "$push_status" -eq 0 ]
    ;;
  # delete branch quickly, without removing it from origin
  brdq)
    branch=${1:-$(current_branch)}
    if [ -z "${1:-}" ]; then
      git switch - || git switch "$(main_branch)"
    fi
    git branch -D "$branch"
    ;;
  # git fix
  f)
    sha=${1:-HEAD}
    git add .
    git commit --fixup "$sha"
    ;;
  # git fix, but manually add files
  fm)
    sha=${1:-HEAD}
    git commit --fixup "$sha"
    ;;
  # git fix, but manually add files and append to previous commit
  fma)
    git commit --amend -C HEAD
    ;;
  # git fix, but append to previous commit
  fa)
    git add .
    git commit --amend -C HEAD
    ;;
  fas)
    git add .
    git rebase-commit-amend "$@"
    ;;
  fash)
    git add .
    git rebase-commit-amend --sha "$@"
    ;;
  # git fix amend, then export
  fae)
    git add .
    git commit --amend -C HEAD
    git push --force-with-lease
    ;;
  *)
    die "Unknown git-alias command: $command_name"
    ;;
esac
