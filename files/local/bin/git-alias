#!/bin/sh

set -eu

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

default_branch() {
  git default-branch
}

current_branch() {
  git symbolic-ref --quiet --short HEAD 2>/dev/null || die "Not on a branch."
}

fetch_origin_branch() {
  branch=$1
  git fetch --no-tags origin "refs/heads/$branch:refs/remotes/origin/$branch"
}

# returns "HEAD~<count>", with count defaulting to 0
reset_target() {
  count=${1:-0}
  printf 'HEAD~%s\n' "$count"
}

command_name=${1:-}
[ -n "$command_name" ] || die "Usage: git-alias <command> [args...]"
shift

case "$command_name" in
  rbm)
    git rebase "origin/$(default_branch)" "$@"
    ;;
  rbb)
    branch=$(current_branch)
    git rebase "origin/$branch" "$@"
    ;;
  rib)
    branch=$(current_branch)
    git rebase -i "$(git merge-base HEAD "origin/$branch")" "$@"
    ;;
  ftb)
    branch=$(current_branch)
    git fetch origin "$branch" "$@"
    ;;
  fr)
    fetch_origin_branch "$(default_branch)"
    git rebase "origin/$(default_branch)"
    ;;
  frm)
    fetch_origin_branch "$(default_branch)"
    ;;
  fre)
    fetch_origin_branch "$(default_branch)"
    git rebase "origin/$(default_branch)"
    git push --force-with-lease
    ;;
  frb)
    branch=$(current_branch)
    git fetch origin "$branch"
    git rebase "origin/$branch"
    ;;
  re)
    git reset --hard "$(reset_target "${1:-}")"
    ;;
  reb)
    git reset --hard "$(git merge-base "origin/$(default_branch)" HEAD)"
    ;;
  rec)
    git reset --hard "$(reset_target "${1:-}")"
    git clean -fd
    ;;
  recb)
    git reset --hard "$(git merge-base "origin/$(default_branch)" HEAD)"
    git clean -fd
    ;;
  res)
    git reset "$(reset_target "${1:-}")"
    ;;
  resb)
    git reset "$(git merge-base "origin/$(default_branch)" HEAD)"
    ;;
  swm)
    git switch --detach "origin/$(default_branch)"
    ;;
  swrb)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git swrb <branch>"
    main_branch=$(default_branch)
    git switch --detach "origin/$main_branch" 2>/dev/null
    git branch -D tmp >/dev/null 2>&1 || true
    git branch tmp "$branch"
    base_sha=$(git merge-base "origin/$main_branch" "$branch")
    head_sha=$(git rev-parse "$branch")
    git branch -D "$branch"
    git switch -c "$branch"
    git cherry-pick "$base_sha...$head_sha"
    ;;
  cpb)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git cpb <branch>"
    git cherry-pick "$(git merge-base "$branch" "origin/$(default_branch)")..$branch" -n
    git commit -am "$branch"
    ;;
  dib)
    git diff "$(git merge-base "origin/$(default_branch)" HEAD)" "$@"
    ;;
  dibq)
    git diff --name-only "$(git merge-base HEAD "origin/$(default_branch)")" "$@"
    ;;
  dim)
    git diff "origin/$(default_branch)" "$@"
    ;;
  dimq)
    git diff --name-only "origin/$(default_branch)" "$@"
    ;;
  brs)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git brs <branch>"
    git switch -c "$branch" "origin/$(default_branch)"
    ;;
  brsm)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git brsm <branch> [commit-count]"
    if [ -n "${2:-}" ]; then
      sha="HEAD~$2"
    else
      sha=$(git merge-base "origin/$(default_branch)" HEAD)
    fi
    git branch "$branch"
    git reset --hard "$sha"
    git switch "$branch"
    ;;
  brt)
    git branch -D ns--test >/dev/null 2>&1 || true
    git switch -c ns--test
    ;;
  brt2)
    git branch -D ns--test-2 >/dev/null 2>&1 || true
    git switch -c ns--test-2
    ;;
  brt3)
    git branch -D ns--test-3 >/dev/null 2>&1 || true
    git switch -c ns--test-3
    ;;
  brtmp)
    branch=$(current_branch)
    git branch -D tmp >/dev/null 2>&1 || true
    git branch tmp "$branch"
    ;;
  brtmps)
    branch=$(current_branch)
    git branch -M "${branch}-tmp"
    git branch -M tmp "$branch"
    git branch -M "${branch}-tmp" tmp
    git switch "$branch"
    ;;
  brd)
    branch=${1:-$(current_branch)}
    main_branch=$(default_branch)
    current_branch_name=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
    if [ "$branch" = "$current_branch_name" ]; then
      [ "$branch" != "$main_branch" ] || die "Cannot delete the default branch ($main_branch) while checked out."
      git switch "$main_branch"
    fi
    push_status=0
    push_output=$(git push --delete origin "$branch" 2>&1) || push_status=$?
    if [ "$push_status" -eq 0 ]; then
      [ -z "$push_output" ] || printf '%s\n' "$push_output" >&2
    else
      case "$push_output" in
        *"remote ref does not exist"*)
          push_status=0
          ;;
        *)
          printf '%s\n' "$push_output" >&2
          ;;
      esac
    fi
    git branch -D "$branch"
    [ "$push_status" -eq 0 ]
    ;;
  brdq)
    branch=${1:-$(current_branch)}
    if [ -z "${1:-}" ]; then
      git switch - || git switch "$(default_branch)"
    fi
    git branch -D "$branch"
    ;;
  f)
    sha=${1:-HEAD}
    git add .
    git commit --fixup "$sha"
    ;;
  fm)
    sha=${1:-HEAD}
    git commit --fixup "$sha"
    ;;
  fma)
    git commit --amend -C HEAD
    ;;
  fa)
    git add .
    git commit --amend -C HEAD
    ;;
  fas)
    git add .
    git rebase-commit-amend "$@"
    ;;
  fash)
    git add .
    git rebase-commit-amend --sha "$@"
    ;;
  fae)
    git add .
    git commit --amend -C HEAD
    git push --force-with-lease
    ;;
  *)
    die "Unknown git-alias command: $command_name"
    ;;
esac
