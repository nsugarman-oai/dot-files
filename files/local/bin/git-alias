#!/bin/sh

set -eu

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

main_branch() {
  git default-branch
}

current_branch() {
  git symbolic-ref --quiet --short HEAD 2>/dev/null || die "Not on a branch."
}

current_upstream_ref() {
  branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null) || return 0
  git rev-parse --quiet --symbolic-full-name "$branch@{upstream}" 2>/dev/null || true
}

fetch_origin_main() {
  main_branch_name=$(main_branch)
  git fetch --no-tags origin "refs/heads/$main_branch_name:refs/remotes/origin/$main_branch_name"
}

rebase_main_branch() {
  main_branch_name=$(main_branch)
  current_branch_name=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)

  if [ "$current_branch_name" = "$main_branch_name" ]; then
    git rebase "origin/$main_branch_name"
    return
  fi

  branch_ref="refs/heads/$main_branch_name"
  old_sha=$(git rev-parse --verify --quiet "$branch_ref") || die "No local branch named $main_branch_name."
  temp_dir=$(mktemp -d "${TMPDIR:-/tmp}/git-frm.XXXXXX")

  cleanup_rebase_worktree() {
    git worktree remove --force "$temp_dir" >/dev/null 2>&1 || true
  }
  trap cleanup_rebase_worktree EXIT HUP INT TERM

  # Rebase in a detached worktree so the caller stays on their current branch.
  git worktree add --detach "$temp_dir" "$old_sha" >/dev/null
  if ! git -C "$temp_dir" rebase "origin/$main_branch_name"; then
    printf 'Rebase failed in temporary worktree: %s\n' "$temp_dir" >&2
    trap - EXIT HUP INT TERM
    exit 1
  fi
  new_sha=$(git -C "$temp_dir" rev-parse HEAD)
  git update-ref -m "git frm: rebase $main_branch_name onto origin/$main_branch_name" "$branch_ref" "$new_sha" "$old_sha"

  cleanup_rebase_worktree
  trap - EXIT HUP INT TERM
}

# returns "HEAD~<count>", with count defaulting to 0
reset_target() {
  count=${1:-0}
  printf 'HEAD~%s\n' "$count"
}

branch_list() {
  count=${1:-all}
  format='%(refname:short)  %(color:brightblack)(%(committerdate:relative))%(color:reset)'

  if [ "$count" = "all" ]; then
    git for-each-ref --color=auto --sort=-committerdate --format="$format" refs/heads
    return
  fi

  git for-each-ref --color=auto --sort=-committerdate --count="$count" --format="$format" refs/heads
}

log_list() {
  count=${1:-all}
  shift || true
  main_branch_name=$(main_branch)
  upstream_ref=$(current_upstream_ref)
  upstream_decorate_arg=''
  if [ -n "$upstream_ref" ]; then
    upstream_decorate_arg="--decorate-refs=$upstream_ref"
  fi

  git_color='never'
  color_time=''
  color_reset=''
  if [ -t 1 ]; then
    git_color='always'
    color_time=$(printf '\033[90m')
    color_reset=$(printf '\033[0m')
    format="%C(yellow)%h%C(reset)%x1f%C(auto)%d%C(reset)%x1f%s%x1f%cr"
  else
    format="%h%x1f%d%x1f%s%x1f%cr"
  fi

  delimiter=$(printf '\037')

  if [ "$count" = "all" ]; then
    git log \
      --decorate=short \
      --decorate-refs=HEAD \
      --decorate-refs=refs/heads \
      --decorate-refs=refs/tags \
      --decorate-refs="refs/remotes/origin/$main_branch_name" \
      $upstream_decorate_arg \
      --color="$git_color" \
      --format="$format" \
      "$@" |
      awk -F "$delimiter" -v color_time="$color_time" -v color_reset="$color_reset" '
        function shorten_relative_time(age) {
          sub(/ ago$/, "", age)
          gsub(/just now/, "now", age)
          gsub(/ seconds?/, "s", age)
          gsub(/ minutes?/, "m", age)
          gsub(/ hours?/, "h", age)
          gsub(/ days?/, "d", age)
          gsub(/ weeks?/, "w", age)
          gsub(/ months?/, "mo", age)
          gsub(/ years?/, "y", age)
          return age
        }
        {
          prefix = $1
          if ($2 != "") {
            prefix = prefix $2
          }
          printf "%s %s %s(%s)%s\n", prefix, $3, color_time, shorten_relative_time($4), color_reset
        }
      '
    return
  fi

  git log \
    --decorate=short \
    --decorate-refs=HEAD \
    --decorate-refs=refs/heads \
    --decorate-refs=refs/tags \
    --decorate-refs="refs/remotes/origin/$main_branch_name" \
    $upstream_decorate_arg \
    --color="$git_color" \
    --max-count="$count" \
    --format="$format" \
    "$@" |
    awk -F "$delimiter" -v color_time="$color_time" -v color_reset="$color_reset" '
      function shorten_relative_time(age) {
        sub(/ ago$/, "", age)
        gsub(/just now/, "now", age)
        gsub(/ seconds?/, "s", age)
        gsub(/ minutes?/, "m", age)
        gsub(/ hours?/, "h", age)
        gsub(/ days?/, "d", age)
        gsub(/ weeks?/, "w", age)
        gsub(/ months?/, "mo", age)
        gsub(/ years?/, "y", age)
        return age
      }
      {
        prefix = $1
        if ($2 != "") {
          prefix = prefix $2
        }
        printf "%s %s %s(%s)%s\n", prefix, $3, color_time, shorten_relative_time($4), color_reset
      }
    '
}

command_name=${1:-}
[ -n "$command_name" ] || die "Usage: git-alias <command> [args...]"
shift

case "$command_name" in
  rbm)
    git rebase "origin/$(main_branch)" "$@"
    ;;
  # rebase on top of origin/branch
  rbb)
    git rebase "origin/$(current_branch)" "$@"
    ;;
  # git rebase -i <merge-base>
  rbi)
    git rebase -i "$(git merge-base "origin/$(main_branch)" HEAD)" "$@"
    ;;
  # fetch remote branch
  ftb)
    git fetch origin "$(current_branch)" "$@"
    ;;
  # fetch origin/main
  ftm)
    fetch_origin_main
    ;;
  # fetch origin/main, then rebase current branch on top of it
  fr)
    fetch_origin_main
    git rebase "origin/$(main_branch)"
    ;;
  # fetch and rebase, then export
  fre)
    fetch_origin_main
    git rebase "origin/$(main_branch)"
    git push --force-with-lease
    ;;
  # fetch origin/<default>, then rebase the default branch without switching branches
  frm)
    fetch_origin_main
    rebase_main_branch
    ;;
  # fetch and rebase branch
  frb)
    branch=$(current_branch)
    git fetch origin "$branch"
    git rebase "origin/$branch"
    ;;
  # reset hard: "g re 4", defaults to "0" if no arg is passed
  re)
    git reset --hard "$(reset_target "${1:-}")"
    ;;
  # reset hard to merge base
  reb)
    git reset --hard "$(git merge-base "origin/$(main_branch)" HEAD)"
    ;;
  # reset hard and clean: "g rec 4", defaults to "0" if no arg is passed
  rec)
    git reset --hard "$(reset_target "${1:-}")"
    git clean -fd
    ;;
  # reset hard and clean to merge base
  recb)
    git reset --hard "$(git merge-base "origin/$(main_branch)" HEAD)"
    git clean -fd
    ;;
  # reset soft, defaults to "0" if no arg is passed
  res)
    git reset "$(reset_target "${1:-}")"
    ;;
  # reset soft to merge base
  resb)
    git reset "$(git merge-base "origin/$(main_branch)" HEAD)"
    ;;
  # commit all with a message, or pass commit flags directly
  ca)
    git add .
    case "${1:-}" in
      "")
        git commit
        ;;
      -*)
        git commit "$@"
        ;;
      *)
        git commit -m "$*"
        ;;
    esac
    ;;
  swm)
    git switch --detach "origin/$(main_branch)"
    ;;
  # switch to rebased branch, done by cherry-picking changes on top of origin/default
  # git swrb branch-to-switch
  swrb)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git swrb <branch>"
    main_branch_name=$(main_branch)
    git switch --detach "origin/$main_branch_name" 2>/dev/null
    git branch -D tmp >/dev/null 2>&1 || true
    git branch tmp "$branch"
    base_sha=$(git merge-base "origin/$main_branch_name" "$branch")
    head_sha=$(git rev-parse "$branch")
    git branch -D "$branch"
    git switch -c "$branch"
    git cherry-pick "$base_sha...$head_sha"
    ;;
  # cherry-pick branch: "g cpb TEST"
  cpb)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git cpb <branch>"
    git cherry-pick "$(git merge-base "$branch" "origin/$(main_branch)")..$branch" -n
    git commit -am "$branch"
    ;;
  # decorated commit log with relative time, limited to 12
  lg)
    log_list 12 "$@"
    ;;
  # decorated commit log with relative time, limited to 30
  lg2)
    log_list 30 "$@"
    ;;
  # decorated commit log with relative time, unlimited
  lg3)
    log_list all "$@"
    ;;
  # diff merge base
  dib)
    git diff "$(git merge-base "origin/$(main_branch)" HEAD)" "$@"
    ;;
  # diff merge base with name-only
  dibq)
    git diff --name-only "$(git merge-base HEAD "origin/$(main_branch)")" "$@"
    ;;
  # diff default branch
  dim)
    git diff "origin/$(main_branch)" "$@"
    ;;
  # diff default branch with name-only
  dimq)
    git diff --name-only "origin/$(main_branch)" "$@"
    ;;
  # branch tips by recency, limited to 18
  br)
    branch_list 18
    ;;
  # branch tips by recency, limited to 36
  br2)
    branch_list 36
    ;;
  # branch tips by recency, unlimited
  br3)
    branch_list all
    ;;
  # start new branch from the default branch
  brs)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git brs <branch>"
    git switch -c "$branch" "origin/$(main_branch)"
    ;;
  # start new branch, moving commits from current branch: "g brsm new-branch"
  brsm)
    branch=${1:-}
    [ -n "$branch" ] || die "Usage: git brsm <branch> [commit-count]"
    if [ -n "${2:-}" ]; then
      sha="HEAD~$2"
    else
      sha=$(git merge-base "origin/$(main_branch)" HEAD)
    fi
    git branch "$branch"
    git reset --hard "$sha"
    git switch "$branch"
    ;;
  # copy changes to ns--test branch
  brt)
    git branch -D ns--test >/dev/null 2>&1 || true
    git switch -c ns--test
    ;;
  brt2)
    git branch -D ns--test-2 >/dev/null 2>&1 || true
    git switch -c ns--test-2
    ;;
  brt3)
    git branch -D ns--test-3 >/dev/null 2>&1 || true
    git switch -c ns--test-3
    ;;
  # git branch tmp - backup changes in tmp branch
  brtmp)
    branch=$(current_branch)
    git branch -D tmp >/dev/null 2>&1 || true
    git branch tmp "$branch"
    ;;
  # git branch tmp swap - swap changes with tmp
  brtmps)
    branch=$(current_branch)
    git branch -M "${branch}-tmp"
    git branch -M tmp "$branch"
    git branch -M "${branch}-tmp" tmp
    git switch "$branch"
    ;;
  # delete branch: "g dr [branch-name=current-branch]"
  brd)
    main_branch_name=$(main_branch)
    current_branch_name=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
    branch=${1:-}
    if [ -z "$branch" ]; then
      [ -n "$current_branch_name" ] || die "Cannot delete the current branch while HEAD is detached."
      branch=$current_branch_name
    fi
    if [ "$branch" = "$current_branch_name" ]; then
      git switch --detach "origin/$main_branch_name"
    fi
    push_status=0
    push_output=$(git push --delete origin "$branch" 2>&1) || push_status=$?
    if [ "$push_status" -eq 0 ]; then
      [ -z "$push_output" ] || printf '%s\n' "$push_output" >&2
    else
      case "$push_output" in
        *"remote ref does not exist"*)
          push_status=0
          ;;
        *)
          printf '%s\n' "$push_output" >&2
          ;;
      esac
    fi
    git branch -D "$branch"
    [ "$push_status" -eq 0 ]
    ;;
  # delete branch quickly, without removing it from origin
  brdq)
    branch=${1:-$(current_branch)}
    if [ -z "${1:-}" ]; then
      git switch - || git switch "$(main_branch)"
    fi
    git branch -D "$branch"
    ;;
  # git fix
  f)
    sha=${1:-HEAD}
    git add .
    git commit --fixup "$sha"
    ;;
  # git fix, but manually add files
  fm)
    sha=${1:-HEAD}
    git commit --fixup "$sha"
    ;;
  # git fix, but manually add files and append to previous commit
  fma)
    git commit --amend -C HEAD
    ;;
  # git fix, but append to previous commit
  fa)
    git add .
    git commit --amend -C HEAD
    ;;
  fas)
    git add .
    git rebase-commit-amend "$@"
    ;;
  fash)
    git add .
    git rebase-commit-amend --sha "$@"
    ;;
  # git fix amend, then export
  fae)
    git add .
    git commit --amend -C HEAD
    git push --force-with-lease
    ;;
  *)
    die "Unknown git-alias command: $command_name"
    ;;
esac
