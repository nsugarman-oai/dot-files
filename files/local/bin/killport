#!/usr/bin/env bash
set -euo pipefail

script_name="${0##*/}"

usage() {
  printf 'Usage: %s port[,port]...\n' "$script_name"
  printf 'Example: %s 6006,6007\n' "$script_name"
}

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

parse_ports() {
  local raw port
  local parts=()

  for raw in "$@"; do
    IFS=',' read -r -a parts <<< "$raw"
    for port in "${parts[@]}"; do
      [ -n "$port" ] || die "$script_name: empty port in: $raw"

      if [[ ! "$port" =~ ^[0-9]+$ ]]; then
        die "$script_name: expected a numeric port, got: $port"
      fi

      if [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
        die "$script_name: port out of range: $port"
      fi

      printf '%s\n' "$port"
    done
  done | sort -n -u
}

join_lines() {
  local separator="$1"
  local joined=""
  local line

  while IFS= read -r line; do
    [ -n "$line" ] || continue

    if [ -n "$joined" ]; then
      joined="${joined}${separator}"
    fi
    joined="${joined}${line}"
  done

  printf '%s' "$joined"
}

pids_for_ports() {
  local ports="$1"
  local port

  while IFS= read -r port; do
    [ -n "$port" ] || continue
    lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true
  done <<< "$ports" | sort -n -u
}

send_signal_to_pids() {
  local signal="$1"
  local pids="$2"
  local pid
  local failed=0

  while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    kill "-$signal" "$pid" 2>/dev/null || failed=1
  done <<< "$pids"

  return "$failed"
}

running_pids() {
  local pids="$1"
  local pid

  while IFS= read -r pid; do
    [ -n "$pid" ] || continue
    kill -0 "$pid" 2>/dev/null || continue
    printf '%s\n' "$pid"
  done <<< "$pids"
}

if [ "$#" -eq 0 ]; then
  usage >&2
  exit 1
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

ports="$(parse_ports "$@")"
ports_display="$(printf '%s\n' "$ports" | join_lines ',')"
pids="$(pids_for_ports "$ports")"

if [ -z "$pids" ]; then
  printf 'no listening processes found on port(s): %s\n' "$ports_display"
  exit 0
fi

pids_display="$(printf '%s\n' "$pids" | join_lines ',')"

send_signal_to_pids TERM "$pids" || true
sleep 1

remaining_pids="$(running_pids "$pids")"
if [ -n "$remaining_pids" ]; then
  send_signal_to_pids KILL "$remaining_pids" || true
  sleep 1
fi

remaining_pids="$(running_pids "$pids")"
if [ -n "$remaining_pids" ]; then
  remaining_display="$(printf '%s\n' "$remaining_pids" | join_lines ',')"
  printf 'failed to kill process(es) %s on port(s): %s\n' "$remaining_display" "$ports_display" >&2
  exit 1
fi

printf 'killed process(es) %s on port(s): %s\n' "$pids_display" "$ports_display"
